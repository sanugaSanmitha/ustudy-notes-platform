NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
STRIPE_SECRET_KEY=your-stripe-secret-key
RESEND_API_KEY=your-resend-api-key
# Staff portal emails (comma-separated)
ADMIN_PORTAL_EMAILS=admin@ustudy.dev
ASSISTANT_PORTAL_EMAILS=assistant@ustudy.dev
SUPPORT_PORTAL_EMAILS=support@ustudy.dev
# Review notification recipients
ADMIN_REVIEW_EMAIL=admin@ustudy.dev,support@ustudy.dev,assistant@ustudy.dev
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
TRANSCRIPT_STORAGE_BUCKET=grade-transcripts
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=your-r2-bucket

# Grade verification (optional overrides; defaults vary by NODE_ENV)
GRADE_MAX_UPLOADS_PER_DAY=3
GRADE_MAX_FILE_SIZE_MB=20
GRADE_MAX_PARSE_RETRIES=2
GRADE_SIGNED_URL_EXPIRES_SECONDS=600
GRADE_REJECT_RETENTION_DAYS=30
GRADE_RETENTION_CRON_SECRET=your-cron-secret

# Course material re-upload window (before the course locks for note publishing)
# Local dev (.env.local): use minutes for fast testing
MATERIAL_REUPLOAD_WINDOW_MINUTES=3
# Production (Vercel / deployed builds): use hours for real users — set in vercel.json or Vercel dashboard
# MATERIAL_REUPLOAD_WINDOW_HOURS=64